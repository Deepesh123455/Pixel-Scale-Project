# ----------------------------------------------------------------------
# Dependencies & Build
# ----------------------------------------------------------------------
node_modules/
dist/
build/
*.tsbuildinfo

# ----------------------------------------------------------------------
# Environment variables & Security (Critical) 🚨
# ----------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem      # AWS ki chaabi galti se bhi push nahi honi chahiye!

# ----------------------------------------------------------------------
# Runtime & OS Files
# ----------------------------------------------------------------------
logs
*.log
.DS_Store
Thumbs.db
.vscode/   # VS Code ki local settings
.idea/

# ----------------------------------------------------------------------
# Project Specific (PixelScale)
# ----------------------------------------------------------------------
tmp/
uploads/

# ----------------------------------------------------------------------
# Database (Drizzle Migrations Meta)
# ----------------------------------------------------------------------
**/migrations/meta/
**/migrations/_meta/
drizzle.config.ts.timestamp*

# ----------------------------------------------------------------------
# Terraform (Infrastructure as Code)
# ----------------------------------------------------------------------
# Local .terraform directories (contains heavy provider plugins)
**/.terraform/*

# .tfstate files (CRITICAL: Contains your cloud infrastructure map and secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore any .tfvars files that might contain local AWS credentials
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# NOTE: .terraform.lock.hcl file ko ignore NAHI karna hai, wo push honi chahiye!